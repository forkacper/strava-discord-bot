# Strava — strava.com/settings/api
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_VERIFY_TOKEN=random_secret_string

# Discord — ustawienia kanału → Integracje → Webhooki
DISCORD_WEBHOOK_URL=

# Redis
REDIS_URL=redis://localhost:6379

# Vercel — domena projektu (bez trailing slash)
APP_BASE_URL=https://twoja-domena.vercel.app
